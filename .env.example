# Copy to .env and fill in your key (never commit .env).
# Get a free key at https://parse.bot — MyKBO player search + box scores.

PARSE_API_KEY=your_parse_api_key_here

# Optional KBO pitcher pool controls:
# KBO_PITCHER_REBUILD=1       # force Oct→today box-score bulk scrape
# KBO_PITCHER_RECENT_ONLY=1   # only last ~14 days (fast daily)
# KBO_PITCHER_SKIP_BULK=1     # per-player logs only (best with PARSE_API_KEY)
# KBO_PITCHER_FULL_SCRAPE=1   # full season_years bulk (very slow)

# Tennis match logs (api.api-tennis.com) — free key at https://api-tennis.com
API_TENNIS_KEY=your_api_tennis_key_here

# Soccer match logs (API-Football / api-sports.io) — free key at https://www.api-football.com
API_FOOTBALL_KEY=your_api_football_key_here

# --- Production API service (sports_prop_edge.deployment) ---
SPE_HOST=0.0.0.0
SPE_PORT=8000
SPE_ENV=production
SPE_LOG_LEVEL=info
SPE_WORKERS=1
SPE_BANKROLL=100.0
# SPE_PROJECT_ROOT=/app
# Optional: require X-API-Key header when set (leave empty to disable auth)
SPE_API_KEY=
SPE_CORS_ORIGINS=*

# Optional scalar type telemetry (zero overhead when disabled)
# SPE_TYPE_TELEMETRY=1
# SPE_SCALAR_DEBUG=1
